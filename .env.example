# Happy-Pythagoras Configuration
# Copy this file to .env and fill in your keys

# --- Search Engine Keys ---
SERPAPI_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=

# --- AI Provider Keys (fill only what you need) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENCODEGO_API_KEY=

# --- Request Settings ---
REQUEST_TIMEOUT=15
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# --- Crawler Settings ---
MAX_CRAWL_DEPTH=2
MAX_CRAWL_PAGES=12

# --- Default Search Engine ---
SEARCH_ENGINE=duckduckgo
